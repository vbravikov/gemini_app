{
  "cli": {
    "version": ">= 18.0.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "store",
      "channel": "preview",
      "autoIncrement": true
    },
    "production": {
      "distribution": "store",
      "autoIncrement": true,
      "channel": "production"
    }
  },
  "submit": {
    "production": {},
    "preview": {
      "android": {
        "releaseStatus": "draft",
        "track": "internal"
      }
    }
  }
}
